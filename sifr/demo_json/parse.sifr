class DemoJsonError(Error):
    message: str

class DemoJsonValue:
    value: int

    def as_int(self) -> Result[int, DemoJsonError]:
        return Ok(self.value)

def parse_json(text: str) -> Result[dict[str, DemoJsonValue], DemoJsonError]:
    if text == "":
        return Err(DemoJsonError(message = "empty json"))
    return Ok({"status_code": DemoJsonValue(value = 200)})

def from_legacy(value: DemoJsonValue) -> Result[DemoJsonValue, DemoJsonError]:
    return Ok(value)
